{
  "name": "workout-planner",
  "version": "0.1.0",
  "description": "Weekly training planner — cycling + weights → Intervals.icu calendar",
  "type": "module",
  "private": true,
  "scripts": {
    "plan": "tsx src/cli.ts plan",
    "status": "tsx src/cli.ts status",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ test/",
    "format": "prettier --write src/ test/",
    "format:check": "prettier --check src/ test/"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "dotenv": "^17.0.0",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "10.2.1",
    "prettier": "3.8.3",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "8.59.0",
    "vitest": "^1.3.0"
  }
}
