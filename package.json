{
  "name": "workout-planner",
  "version": "0.1.0",
  "description": "Weekly training planner — cycling + weights → Intervals.icu calendar",
  "type": "module",
  "private": true,
  "license": "MIT",
  "author": "Brennan Moore",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zamiang/intervals-icu-planner.git"
  },
  "scripts": {
    "plan": "tsx src/cli.ts plan",
    "status": "tsx src/cli.ts status",
    "check": "tsx src/cli.ts check",
    "push-week": "tsx scripts/push-week.ts",
    "events": "tsx scripts/events.ts",
    "push-strength": "tsx scripts/push-strength.ts",
    "push-strength:hevy": "tsx scripts/push-strength-hevy.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ test/",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "dotenv": "^17.0.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "^25.0.0",
    "eslint": "10.5.0",
    "prettier": "3.8.4",
    "tsx": "^4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.0",
    "vitest": "4.1.9"
  }
}
